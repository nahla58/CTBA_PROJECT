# CTBA Platform Configuration

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Option 1: SQLite (par défaut, local development)
# DATABASE_URL=sqlite:///ctba_platform.db

# Option 2: PostgreSQL (recommandé pour production)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://ctba_user:ctba_password123@localhost:5432/ctba_platform

# Ou variables séparées:
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ctba_platform
DB_USER=ctba_user
DB_PASSWORD=ctba_password123

# ============================================================================
# CVE DATA SOURCES
# ============================================================================

# NVD (National Vulnerability Database)
NVD_API_KEY=

# CVE Details API Token
CVEDETAILS_API_TOKEN=

# CVE.org (MITRE) - No token needed, uses public API
# CVEORG_ENABLED=true

# MSRC (Microsoft Security Response Center)
# MSRC_API_KEY=

# Hackuity (optional)
# HACKUITY_API_KEY=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Debug mode
DEBUG=False

# API Port
API_PORT=8000
API_HOST=0.0.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Admin credentials (for initialization)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DEPLOYMENT (Cloud/DevOps)
# ============================================================================

# Kubernetes namespace (if applicable)
# K8S_NAMESPACE=ctba-prod

# AWS credentials (if using AWS)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# GCP credentials (if using Google Cloud)
# GCP_PROJECT_ID=
# GCP_CREDENTIALS_FILE=

# Azure credentials (if using Azure)
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
